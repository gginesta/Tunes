# Spotify API client ID (used by the frontend)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Server port (optional, defaults to 3000)
PORT=3000

# Node environment (set to "production" for deployment)
NODE_ENV=production

# Comma-separated list of origins allowed to reach the server cross-origin.
# Leave unset in production when the server serves the app itself (same
# origin needs no CORS). Dev defaults to allowing any origin.
# ALLOWED_ORIGINS=https://tunes.example.com

# 64 hex chars (32 bytes) used to encrypt Spotify tokens at rest in SQLite.
# Optional: when unset, a key is auto-generated at data/.token-key.
# Generate with: openssl rand -hex 32
# TOKEN_ENCRYPTION_KEY=
